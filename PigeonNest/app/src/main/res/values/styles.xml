<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.PigeonNest.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">64dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="Widget.PigeonNest.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">18sp</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="Widget.PigeonNest.Input" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxStrokeColor">@color/input_border</item>
        <item name="boxStrokeWidth">2dp</item>
    </style>
</resources>
