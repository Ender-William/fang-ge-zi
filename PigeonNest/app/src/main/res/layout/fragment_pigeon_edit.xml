<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/button_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="返回"
                android:src="@drawable/ic_back"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="编辑鸽子信息"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Step indicator -->
        <TextView
            android:id="@+id/text_step_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="第 1 步，共 3 步"
            android:textColor="@color/primary_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_step_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="基本信息"
            android:textColor="@color/text_secondary"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/dot_step1"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_step_active" />

            <View
                android:id="@+id/line_step1"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@color/divider" />

            <View
                android:id="@+id/dot_step2"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_step_inactive" />

            <View
                android:id="@+id/line_step2"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@color/divider" />

            <View
                android:id="@+id/dot_step3"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_step_inactive" />
        </LinearLayout>

        <!-- Step 1: Basic Info -->
        <LinearLayout
            android:id="@+id/container_step1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="鸽子名字 *"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/edit_name"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_input"
                android:hint="例如: 小白"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="脚环号 *"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/edit_ring_number"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_input"
                android:hint="例如: 2024-BJ-001"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="性别"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <RadioGroup
                android:id="@+id/radio_group_gender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radio_male"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:checked="true"
                    android:text="雄"
                    android:textColor="@color/male_blue"
                    android:textSize="20sp" />

                <RadioButton
                    android:id="@+id/radio_female"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="雌"
                    android:textColor="@color/female_pink"
                    android:textSize="20sp" />

                <RadioButton
                    android:id="@+id/radio_unknown"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="未知"
                    android:textColor="@color/text_secondary"
                    android:textSize="20sp" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="出生日期"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_birth_date"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:text="选择出生日期"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                app:strokeColor="@color/input_border" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="羽色"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <GridLayout
                android:id="@+id/grid_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="3"
                android:rowCount="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_color_rain"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="雨点"
                    android:textSize="18sp"
                    app:strokeColor="@color/input_border" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_color_gray"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="灰"
                    android:textSize="18sp"
                    app:strokeColor="@color/input_border" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_color_red"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="红"
                    android:textSize="18sp"
                    app:strokeColor="@color/input_border" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_color_white"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="白"
                    android:textSize="18sp"
                    app:strokeColor="@color/input_border" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_color_black"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="黑"
                    android:textSize="18sp"
                    app:strokeColor="@color/input_border" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_color_flower"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="花"
                    android:textSize="18sp"
                    app:strokeColor="@color/input_border" />
            </GridLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_color_custom"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="其他羽色..."
                android:textColor="@color/primary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/text_custom_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="当前状态"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <GridLayout
                android:id="@+id/grid_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="2"
                android:rowCount="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_status_active"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="在养"
                    android:textSize="18sp"
                    app:strokeColor="@color/input_border" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_status_sold"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="已售"
                    android:textSize="18sp"
                    app:strokeColor="@color/input_border" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_status_deceased"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="已故"
                    android:textSize="18sp"
                    app:strokeColor="@color/input_border" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_status_gifted"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="赠送"
                    android:textSize="18sp"
                    app:strokeColor="@color/input_border" />
            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="全身照"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_take_photo"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="拍照"
                    android:textSize="18sp"
                    app:strokeColor="@color/input_border" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_pick_photo"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="从相册选择"
                    android:textSize="18sp"
                    app:strokeColor="@color/input_border" />
            </LinearLayout>

            <ImageView
                android:id="@+id/image_preview"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="12dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="眼睛照片"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_take_eye_photo"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="拍照"
                    android:textSize="18sp"
                    app:strokeColor="@color/input_border" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_pick_eye_photo"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="从相册选择"
                    android:textSize="18sp"
                    app:strokeColor="@color/input_border" />
            </LinearLayout>

            <ImageView
                android:id="@+id/image_eye_preview"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="12dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="备注"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/edit_notes"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_input"
                android:gravity="top"
                android:hint="添加备注信息..."
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />
        </LinearLayout>

        <!-- Step 2: Location Info -->
        <LinearLayout
            android:id="@+id/container_step2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="鸽棚"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_select_loft"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:text="选择鸽棚"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                app:strokeColor="@color/input_border" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="笼位号"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/edit_cage_number"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_input"
                android:hint="例如: A-12"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />
        </LinearLayout>

        <!-- Step 3: Family Relations -->
        <LinearLayout
            android:id="@+id/container_step3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="父亲（雄鸽）"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_select_father"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:text="不设置"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                app:strokeColor="@color/input_border" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="母亲（雌鸽）"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_select_mother"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:text="不设置"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                app:strokeColor="@color/input_border" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="配偶"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_select_mate"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:text="不设置"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                app:strokeColor="@color/input_border" />
        </LinearLayout>

        <!-- Navigation buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_prev"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="上一步"
                android:textSize="18sp"
                android:visibility="gone"
                app:strokeColor="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_next"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="下一步"
                android:textSize="20sp"
                android:textStyle="bold"
                app:backgroundTint="@color/primary"
                app:cornerRadius="16dp" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
